<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ares_bg_dark"
    android:orientation="vertical"
    android:padding="16dp"
    tools:context=".feature.control.Control">

    <!-- ══ TABS MANUAL / AUTÓNOMO ══ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:orientation="horizontal">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:background="@drawable/bg_tab_active"
            android:gravity="center"
            android:padding="12dp"
            android:text="@string/control_tab_manual"
            android:textColor="@color/ares_text_primary"
            android:textStyle="bold" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:background="@drawable/bg_tab_inactive"
            android:gravity="center"
            android:padding="12dp"
            android:text="@string/control_tab_autonomo"
            android:textColor="@color/ares_text_secondary"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- ══ CARD CÁMARA ══ -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginBottom="24dp"
        app:cardBackgroundColor="@color/ares_control_card_camera"
        app:cardCornerRadius="8dp"
        app:strokeColor="@color/ares_blue"
        app:strokeWidth="1dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <WebView
                android:id="@+id/webview_stream"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="12dp">

                <!-- LIVE badge -->
                <TextView
                    android:id="@+id/tv_live"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/control_live"
                    android:textColor="@color/ares_green"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <!-- Latencia -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_toEndOf="@id/tv_live"
                    android:text="@string/control_latencia_default"
                    android:textColor="@color/ares_text_secondary"
                    android:textSize="12sp" />

                <!-- REC badge -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:text="@string/control_rec"
                    android:textColor="@color/ares_orange"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <!-- Info cámara -->
                <TextView
                    android:id="@+id/tv_camera_info"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentBottom="true"
                    android:text="@string/control_cam_info"
                    android:textColor="@color/ares_blue"
                    android:textSize="10sp" />
            </RelativeLayout>
        </RelativeLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- ══ BOTONES DE ACCIÓN ══ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="32dp"
        android:gravity="center"
        android:orientation="horizontal">

        <!-- Cámara -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/btn_camara"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginHorizontal="6dp"
            app:cardBackgroundColor="@color/ares_card_bg"
            app:cardCornerRadius="24dp"
            app:strokeColor="@color/ares_blue"
            app:strokeWidth="1dp">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:contentDescription="@string/cd_btn_camara"
                android:src="@drawable/ic_camara"
                app:tint="@color/ares_blue" />
        </com.google.android.material.card.MaterialCardView>

        <!-- Video -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/btn_video"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginHorizontal="6dp"
            app:cardBackgroundColor="@color/ares_card_bg"
            app:cardCornerRadius="24dp">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:contentDescription="@string/cd_btn_video"
                android:src="@drawable/ic_video"
                app:tint="@color/ares_text_primary" />
        </com.google.android.material.card.MaterialCardView>

        <!-- Micrófono -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/btn_mic"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginHorizontal="6dp"
            app:cardBackgroundColor="@color/ares_card_bg"
            app:cardCornerRadius="24dp">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:contentDescription="@string/cd_btn_mic"
                android:src="@drawable/ic_mic"
                app:tint="@color/ares_text_primary" />
        </com.google.android.material.card.MaterialCardView>

        <!-- Switch/Bucle -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/btn_switch"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginHorizontal="6dp"
            app:cardBackgroundColor="@color/ares_card_bg"
            app:cardCornerRadius="24dp">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:contentDescription="@string/cd_btn_switch"
                android:src="@drawable/ic_bucle"
                app:tint="@color/ares_text_primary" />
        </com.google.android.material.card.MaterialCardView>

        <!-- Mapa -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/btn_mapa"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginHorizontal="6dp"
            app:cardBackgroundColor="@color/ares_card_bg"
            app:cardCornerRadius="24dp"
            app:strokeColor="@color/ares_orange"
            app:strokeWidth="1dp">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:contentDescription="@string/nav_mapa"
                android:src="@drawable/ic_mapa"
                app:tint="@color/ares_orange" />
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>

    <!-- ══ JOYSTICK + BRÚJULA + VELOCIDAD ══ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="180dp"
        android:baselineAligned="false"
        android:orientation="horizontal">

        <!-- Brújula -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:contentDescription="@string/cd_brujula"
                android:background="@drawable/circle_dark"
                android:backgroundTint="@color/ares_surface" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/control_rumbo_default"
                android:textAlignment="center"
                android:textColor="@color/ares_blue"
                android:textSize="10sp" />
        </LinearLayout>

        <!-- Joystick -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/joystick_container"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="2">

            <View
                android:id="@+id/joystick_base"
                android:layout_width="160dp"
                android:layout_height="160dp"
                android:background="@drawable/circle_dark"
                android:backgroundTint="@color/ares_surface"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <View
                android:id="@+id/joystick_handle"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/circle_blue_solid"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />
        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- Velocidad + Motor -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/control_velocidad_default"
                android:textAlignment="center"
                android:textColor="@color/ares_text_primary"
                android:textSize="14sp"
                android:textStyle="bold" />

            <View
                android:layout_width="4dp"
                android:layout_height="80dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="8dp"
                android:background="@color/ares_card_stroke" />

            <TextView
                android:id="@+id/tv_mode_indicator"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/control_motor"
                android:textColor="@color/ares_blue"
                android:textSize="10sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

</LinearLayout>