<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/ares_card_bg"
    android:padding="24dp">

    <!-- Título -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="EDITAR PERFIL"
        android:textColor="@color/ares_text_primary"
        android:textSize="16sp"
        android:textStyle="bold"
        android:fontFamily="monospace"
        android:letterSpacing="0.08"
        android:layout_marginBottom="20dp" />

    <!-- Nombre -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="NOMBRE"
        android:textColor="@color/ares_text_secondary"
        android:textSize="10sp"
        android:fontFamily="monospace"
        android:letterSpacing="0.1"
        android:layout_marginBottom="6dp" />

    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        app:boxBackgroundColor="@color/ares_bg_dark"
        app:boxBackgroundMode="filled"
        app:boxCornerRadiusTopStart="8dp"
        app:boxCornerRadiusTopEnd="8dp"
        app:boxCornerRadiusBottomStart="8dp"
        app:boxCornerRadiusBottomEnd="8dp"
        app:boxStrokeColor="@color/ares_blue"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etEditarNombre"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="textPersonName"
            android:textColor="@color/ares_text_primary"
            android:hint="Nombre del operador" />
    </com.google.android.material.textfield.TextInputLayout>

    <!-- Correo -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="CORREO"
        android:textColor="@color/ares_text_secondary"
        android:textSize="10sp"
        android:fontFamily="monospace"
        android:letterSpacing="0.1"
        android:layout_marginBottom="6dp" />

    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        app:boxBackgroundColor="@color/ares_bg_dark"
        app:boxBackgroundMode="filled"
        app:boxCornerRadiusTopStart="8dp"
        app:boxCornerRadiusTopEnd="8dp"
        app:boxCornerRadiusBottomStart="8dp"
        app:boxCornerRadiusBottomEnd="8dp"
        app:boxStrokeColor="@color/ares_blue"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etEditarCorreo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="textEmailAddress"
            android:textColor="@color/ares_text_primary"
            android:hint="correo@ejemplo.com" />
    </com.google.android.material.textfield.TextInputLayout>

    <!-- ID Operador -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="ID OPERADOR"
        android:textColor="@color/ares_text_secondary"
        android:textSize="10sp"
        android:fontFamily="monospace"
        android:letterSpacing="0.1"
        android:layout_marginBottom="6dp" />

    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        app:boxBackgroundColor="@color/ares_bg_dark"
        app:boxBackgroundMode="filled"
        app:boxCornerRadiusTopStart="8dp"
        app:boxCornerRadiusTopEnd="8dp"
        app:boxCornerRadiusBottomStart="8dp"
        app:boxCornerRadiusBottomEnd="8dp"
        app:boxStrokeColor="@color/ares_blue"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etEditarIdOperador"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="text"
            android:textColor="@color/ares_text_primary"
            android:fontFamily="monospace"
            android:hint="OP-20251047" />
    </com.google.android.material.textfield.TextInputLayout>

    <!-- Botones -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCancelarEdicion"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:text="CANCELAR"
            android:textColor="@color/ares_text_secondary"
            android:textSize="12sp"
            android:textStyle="bold"
            android:fontFamily="monospace"
            app:backgroundTint="@color/ares_bg_dark"
            app:strokeColor="@color/ares_card_stroke"
            app:strokeWidth="1dp"
            app:cornerRadius="8dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnGuardarEdicion"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="GUARDAR"
            android:textColor="@color/ares_card_bg"
            android:textSize="12sp"
            android:textStyle="bold"
            android:fontFamily="monospace"
            app:backgroundTint="@color/ares_blue"
            app:cornerRadius="8dp" />
    </LinearLayout>

</LinearLayout>