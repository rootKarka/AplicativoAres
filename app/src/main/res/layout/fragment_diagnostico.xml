<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ares_bg_dark">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- ══ CARD: CONEXIÓN ══ -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="12dp"
                app:cardBackgroundColor="@color/ares_card_bg"
                app:strokeColor="@color/ares_blue"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Título -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/sistema_conexion"
                            android:textColor="@color/ares_blue"
                            android:textSize="18sp"
                            android:textStyle="bold" />

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:contentDescription="@string/cd_icono_wifi"
                            android:src="@drawable/ic_wifi"
                            app:tint="@color/ares_blue" />
                    </LinearLayout>

                    <!-- Subtítulo -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="@string/sistema_puertos_protocolos"
                        android:textColor="@color/ares_text_secondary"
                        android:textSize="12sp" />

                    <!-- Intensidad Wi-Fi -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="@string/sistema_intensidad_wifi"
                        android:textColor="@color/ares_text_primary"
                        android:textSize="14sp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:layout_marginTop="4dp">

                        <ProgressBar
                            android:layout_width="0dp"
                            android:layout_height="6dp"
                            android:layout_weight="1"
                            android:max="100"
                            android:progress="82"
                            style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                            android:progressTint="@color/ares_blue"/>

                        <TextView
                            android:id="@+id/tvDbm"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:text="@string/sistema_dbm_default"
                            android:textColor="@color/ares_blue"
                            android:textSize="15sp"
                            android:textStyle="bold"/>
                    </LinearLayout>

                    <!-- Latencia + Servidor -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp">

                        <!-- Latencia -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/latencia_label"
                                android:textColor="@color/ares_text_secondary"
                                android:textSize="12sp" />

                            <TextView
                                android:id="@+id/tvLatenciaSistema"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/control_latencia_default"
                                android:textColor="@color/ares_text_primary"
                                android:textSize="20sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <!-- Servidor -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/sistema_servidor"
                                android:textColor="@color/ares_text_secondary"
                                android:textSize="12sp" />

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:gravity="center_vertical">

                                <View
                                    android:layout_width="8dp"
                                    android:layout_height="8dp"
                                    android:background="@drawable/green_dot" />

                                <TextView
                                    android:id="@+id/tvEstadoServidor"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="6dp"
                                    android:text="@string/sistema_django_online"
                                    android:textColor="@color/ares_green"
                                    android:textSize="14sp"
                                    android:textStyle="bold" />
                            </LinearLayout>
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ══ CARD: SENSORES RAW ══ -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="12dp"
                app:cardBackgroundColor="@color/ares_card_bg"
                app:strokeColor="@color/ares_yellow"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Título -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/sistema_sensores_raw"
                            android:textColor="@color/ares_yellow"
                            android:textSize="18sp"
                            android:textStyle="bold" />

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:contentDescription="@string/cd_icono_sensores"
                            android:src="@drawable/ic_sensors"
                            app:tint="@color/ares_yellow" />
                    </LinearLayout>

                    <!-- Filas sensores -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:orientation="vertical">

                        <!-- DHT11 -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:padding="12dp">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/sistema_sensor_dht11"
                                android:textColor="@color/ares_text_primary"
                                android:textSize="16sp" />

                            <TextView
                                android:id="@+id/tvDht11"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/sistema_dht11_default"
                                android:textColor="@color/ares_blue"
                                android:textSize="16sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <!-- MQ-2 -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:padding="12dp">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/sistema_sensor_mq2"
                                android:textColor="@color/ares_text_primary"
                                android:textSize="16sp" />

                            <TextView
                                android:id="@+id/tvMq2"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/sistema_mq2_default"
                                android:textColor="@color/ares_blue"
                                android:textSize="16sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <!-- Voltaje bus -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:padding="12dp">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/sistema_voltaje_bus"
                                android:textColor="@color/ares_text_primary"
                                android:textSize="16sp" />

                            <TextView
                                android:id="@+id/tvVoltaje"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/sistema_voltaje_default"
                                android:textColor="@color/ares_blue"
                                android:textSize="16sp"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ══ CARD: REGISTRO CRÍTICO ══ -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardBackgroundColor="@color/ares_card_bg">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Título -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:contentDescription="@string/cd_icono_warning"
                            android:src="@drawable/ic_warning"
                            app:tint="@color/ares_orange" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:text="@string/sistema_registro_critico"
                            android:textColor="@color/ares_orange"
                            android:textSize="16sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <!-- Logs — estos son datos dinámicos, se rellenan desde el Fragment -->
                    <LinearLayout
                        android:id="@+id/contenedorLogs"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:orientation="vertical">

                        <!-- Log 1 -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/sistema_log1_hora"
                            android:textColor="@color/ares_text_secondary"
                            android:textSize="12sp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/sistema_log1_msg"
                            android:textColor="@color/ares_text_primary" />

                        <!-- Log 2 -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:text="@string/sistema_log2_hora"
                            android:textColor="@color/ares_text_secondary"
                            android:textSize="12sp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/sistema_log2_msg"
                            android:textColor="@color/ares_yellow" />

                        <!-- Log 3 -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:text="@string/sistema_log3_hora"
                            android:textColor="@color/ares_text_secondary"
                            android:textSize="12sp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/sistema_log3_msg"
                            android:textColor="@color/ares_text_primary" />

                        <!-- Log 4 -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:text="@string/sistema_log4_hora"
                            android:textColor="@color/ares_text_secondary"
                            android:textSize="12sp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/sistema_log4_msg"
                            android:textColor="@color/ares_red"
                            android:textStyle="bold" />

                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- ══ CARD FLOTANTE "POR HACER" ══ -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardPorHacer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:layout_margin="16dp"
        app:cardBackgroundColor="#FF9800"
        app:cardCornerRadius="16dp"
        app:cardElevation="12dp"
        app:strokeColor="@color/ares_orange_report"
        app:strokeWidth="1dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="20dp"
            android:paddingEnd="12dp"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/sistema_por_hacer"
                android:textColor="#000000"
                android:textSize="17sp"
                android:textStyle="bold" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnVista"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/sistema_btn_vista"
                android:textColor="#000000"
                android:textSize="15sp"
                android:textStyle="bold"
                app:backgroundTint="@color/ares_card_bg"
                app:cornerRadius="20dp"
                style="@style/Widget.Material3.Button" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>