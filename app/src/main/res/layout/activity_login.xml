<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ares_bg_dark"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="32dp">

    <ImageView
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:layout_marginBottom="12dp"
        android:src="@drawable/ares_logo_app"
        app:tint="@color/logo_app_color"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/login_titulo_proyecto"
        android:textAlignment="center"
        android:textColor="@color/ares_text_primary"
        android:textSize="26sp"
        android:textStyle="bold"
        android:fontFamily="monospace"
        android:letterSpacing="0.15"
        android:layout_marginBottom="6dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/login_subtitulo_tactico"
        android:textAlignment="center"
        android:textColor="@color/ares_blue"
        android:textSize="10sp"
        android:fontFamily="monospace"
        android:letterSpacing="0.12"
        android:layout_marginBottom="36dp"/>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/ares_card_stroke"
        android:layout_marginBottom="28dp"/>

    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:hint="@string/hint_correo_operador"
        app:boxBackgroundColor="@color/ares_card_bg"
        app:boxBackgroundMode="filled"
        app:boxCornerRadiusTopStart="8dp"
        app:boxCornerRadiusTopEnd="8dp"
        app:boxCornerRadiusBottomStart="8dp"
        app:boxCornerRadiusBottomEnd="8dp"
        app:boxStrokeColor="@color/ares_blue"
        app:boxStrokeWidth="1dp"
        app:hintTextColor="@color/ares_blue"
        app:startIconDrawable="@android:drawable/ic_dialog_email"
        app:startIconTint="@color/ares_blue"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/et_email"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="textEmailAddress"
            android:textColor="@color/ares_text_primary"
            android:textColorHint="@color/ares_text_secondary"/>
    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="32dp"
        android:hint="@string/hint_contrasena"
        app:boxBackgroundColor="@color/ares_card_bg"
        app:boxBackgroundMode="filled"
        app:boxCornerRadiusTopStart="8dp"
        app:boxCornerRadiusTopEnd="8dp"
        app:boxCornerRadiusBottomStart="8dp"
        app:boxCornerRadiusBottomEnd="8dp"
        app:boxStrokeColor="@color/ares_blue"
        app:boxStrokeWidth="1dp"
        app:hintTextColor="@color/ares_blue"
        app:passwordToggleEnabled="true"
        app:passwordToggleTint="@color/ares_blue"
        app:startIconDrawable="@android:drawable/ic_lock_lock"
        app:startIconTint="@color/ares_blue"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/et_password"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="textPassword"
            android:textColor="@color/ares_text_primary"
            android:textColorHint="@color/ares_text_secondary"/>
    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_login"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="@string/btn_iniciar_mision"
        android:textSize="14sp"
        android:textStyle="bold"
        android:textColor="@color/ares_white"
        android:fontFamily="monospace"
        android:letterSpacing="0.15"
        app:backgroundTint="@color/ares_blue"
        app:cornerRadius="8dp"/>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/ares_card_stroke"
        android:layout_marginTop="32dp"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/login_footer"
        android:textAlignment="center"
        android:textColor="@color/ares_text_secondary"
        android:textSize="9sp"
        android:fontFamily="monospace"
        android:letterSpacing="0.1"/>

</LinearLayout>