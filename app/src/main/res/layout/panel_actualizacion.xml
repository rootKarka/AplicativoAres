<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/layoutContenidoActualizacion"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:visibility="visible">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="10dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/telemetria_automatizada"
            android:textColor="@color/ares_blue_report"
            android:textSize="11sp"
            android:textStyle="bold"
            android:letterSpacing="0.05" />

        <View
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:background="@drawable/bg_dot_active" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@drawable/bg_card_telemetry"
        android:layout_marginBottom="24dp">

        <View
            android:layout_width="4dp"
            android:layout_height="match_parent"
            android:background="@color/ares_blue_report" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp">

                <TextView
                    android:id="@+id/tvTime"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/placeholder_hora"
                    android:textColor="@color/ares_white"
                    android:textSize="52sp"
                    android:textStyle="bold"
                    android:fontFamily="monospace" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/unidad_horas"
                    android:textColor="@color/ares_grey"
                    android:textSize="14sp"
                    android:fontFamily="monospace"
                    android:layout_marginTop="20dp" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/ares_border"
                android:layout_marginBottom="16dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/bg_pill_grey"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:layout_marginEnd="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="⚗"
                        android:textSize="18sp"
                        android:textColor="@color/ares_blue_report"
                        android:layout_marginEnd="10dp" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/etiqueta_gas"
                            android:textColor="@color/ares_grey"
                            android:textSize="9sp"
                            android:fontFamily="monospace" />

                        <TextView
                            android:id="@+id/tvGas"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/placeholder_gas"
                            android:textColor="@color/ares_white"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:fontFamily="monospace" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/bg_pill_grey"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:layout_marginStart="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🌡"
                        android:textSize="18sp"
                        android:layout_marginEnd="10dp" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/etiqueta_temperatura"
                            android:textColor="@color/ares_grey"
                            android:textSize="9sp"
                            android:fontFamily="monospace" />

                        <TextView
                            android:id="@+id/tvTemp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/placeholder_temperatura"
                            android:textColor="@color/ares_white"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:fontFamily="monospace" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/nivel_gravedad_operativa"
        android:textColor="@color/ares_blue_report"
        android:textSize="11sp"
        android:textStyle="bold"
        android:letterSpacing="0.05"
        android:layout_marginBottom="10dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="88dp"
        android:orientation="horizontal"
        android:layout_marginBottom="24dp">

        <LinearLayout
            android:id="@+id/btnGravedadNormal"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@drawable/bg_severity_card"
            android:gravity="center"
            android:orientation="vertical"
            android:layout_marginEnd="6dp"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✓"
                android:textSize="24sp"
                android:textColor="@color/ares_green"
                android:layout_marginBottom="6dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/normal"
                android:textColor="@color/ares_grey"
                android:textSize="10sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/btnGravedadPrecaucion"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@drawable/bg_severity_card"
            android:gravity="center"
            android:orientation="vertical"
            android:layout_marginStart="6dp"
            android:layout_marginEnd="6dp"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⚠"
                android:textSize="24sp"
                android:textColor="@color/ares_yellow"
                android:layout_marginBottom="6dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/precaucion"
                android:textColor="@color/ares_grey"
                android:textSize="10sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/btnGravedadCritico"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@drawable/bg_severity_card_critical"
            android:gravity="center"
            android:orientation="vertical"
            android:layout_marginStart="6dp"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="!"
                android:textSize="24sp"
                android:textColor="@color/ares_red"
                android:textStyle="bold"
                android:layout_marginBottom="6dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/critico"
                android:textColor="@color/ares_grey"
                android:textSize="10sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/notas_rapidas_campo"
        android:textColor="@color/ares_blue_report"
        android:textSize="11sp"
        android:textStyle="bold"
        android:letterSpacing="0.05"
        android:layout_marginBottom="10dp" />

    <EditText
        android:id="@+id/etNotasActualizacion"
        android:layout_width="match_parent"
        android:layout_height="120dp"
        android:background="@drawable/bg_input_field"
        android:gravity="top"
        android:padding="14dp"
        android:hint="@string/hint_notas_actualizacion"
        android:textColorHint="@color/ares_grey"
        android:textColor="@color/ares_white"
        android:textSize="13sp"
        android:inputType="textMultiLine"
        android:layout_marginBottom="20dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/accion_recomendada"
        android:textColor="@color/ares_blue_report"
        android:textSize="11sp"
        android:textStyle="bold"
        android:letterSpacing="0.05"
        android:layout_marginBottom="10dp" />

    <EditText
        android:id="@+id/etAccionRecomendada"
        android:layout_width="match_parent"
        android:layout_height="90dp"
        android:background="@drawable/bg_input_field"
        android:gravity="top"
        android:padding="14dp"
        android:hint="@string/hint_accion_recomendada"
        android:textColorHint="@color/ares_grey"
        android:textColor="@color/ares_white"
        android:textSize="13sp"
        android:inputType="textMultiLine"
        android:layout_marginBottom="20dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/victimas_registradas"
        android:textColor="@color/ares_blue_report"
        android:textSize="11sp"
        android:textStyle="bold"
        android:letterSpacing="0.05"
        android:layout_marginBottom="10dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_severity_card"
        android:padding="16dp"
        android:layout_marginBottom="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/victimas_heridas"
                android:textColor="@color/ares_white"
                android:textSize="14sp" />

            <LinearLayout
                android:layout_width="130dp"
                android:layout_height="44dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_pill_grey">

                <Button
                    android:id="@+id/btnActHeridosMinus"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:text="−"
                    android:textSize="20sp"
                    android:textColor="@color/ares_grey"
                    android:background="?attr/selectableItemBackground"
                    android:stateListAnimator="@null" />

                <TextView
                    android:id="@+id/tvActHeridosCount"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="@string/contador_cero"
                    android:textColor="@color/ares_blue_report"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:fontFamily="monospace" />

                <Button
                    android:id="@+id/btnActHeridosPlus"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:text="+"
                    android:textSize="20sp"
                    android:textColor="@color/ares_grey"
                    android:background="?attr/selectableItemBackground"
                    android:stateListAnimator="@null" />
            </LinearLayout>
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/ares_border"
            android:layout_marginVertical="10dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/victimas_fallecidas"
                android:textColor="@color/ares_white"
                android:textSize="14sp" />

            <LinearLayout
                android:layout_width="130dp"
                android:layout_height="44dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_pill_grey">

                <Button
                    android:id="@+id/btnActFallecidasMinus"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:text="−"
                    android:textSize="20sp"
                    android:textColor="@color/ares_grey"
                    android:background="?attr/selectableItemBackground"
                    android:stateListAnimator="@null" />

                <TextView
                    android:id="@+id/tvActFallecidasCount"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="@string/contador_cero"
                    android:textColor="@color/ares_red"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:fontFamily="monospace" />

                <Button
                    android:id="@+id/btnActFallecidasPlus"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:text="+"
                    android:textSize="20sp"
                    android:textColor="@color/ares_grey"
                    android:background="?attr/selectableItemBackground"
                    android:stateListAnimator="@null" />
            </LinearLayout>
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/ares_border"
            android:layout_marginVertical="10dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/victimas_rescatadas"
                android:textColor="@color/ares_white"
                android:textSize="14sp" />

            <LinearLayout
                android:layout_width="130dp"
                android:layout_height="44dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_pill_grey">

                <Button
                    android:id="@+id/btnActRescatadasMinus"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:text="−"
                    android:textSize="20sp"
                    android:textColor="@color/ares_grey"
                    android:background="?attr/selectableItemBackground"
                    android:stateListAnimator="@null" />

                <TextView
                    android:id="@+id/tvActRescatadasCount"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="@string/contador_cero"
                    android:textColor="@color/ares_green"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:fontFamily="monospace" />

                <Button
                    android:id="@+id/btnActRescatadasPlus"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:text="+"
                    android:textSize="20sp"
                    android:textColor="@color/ares_grey"
                    android:background="?attr/selectableItemBackground"
                    android:stateListAnimator="@null" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <Button
        android:id="@+id/btnEnviarActualizacion"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginBottom="16dp"
        android:backgroundTint="@color/ares_blue_report"
        android:text="@string/btn_enviar_actualizacion"
        android:textColor="@color/ares_black"
        android:textStyle="bold"
        android:textSize="13sp"
        android:stateListAnimator="@null" />

</LinearLayout>