<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    tools:context=".ui.MainActivity">

    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/nav_host_fragment"
        android:name="androidx.navigation.fragment.NavHostFragment"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:defaultNavHost="true"
        app:navGraph="@navigation/nav_graph"
        app:layout_constraintTop_toBottomOf="@id/appBarLayout"
        app:layout_constraintBottom_toTopOf="@id/menu_nav" />

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/menu_nav"
        android:layout_width="match_parent"
        android:layout_height="90dp"
        app:menu="@menu/menu"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent" />

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintRight_toRightOf="parent">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/topAppBar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:menu="@menu/top_bar_menu"
            app:title="@string/app_name" />
    </com.google.android.material.appbar.AppBarLayout>

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab_mensaje"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginBottom="204dp"
        android:layout_marginEnd="16dp"
        android:visibility="invisible"
        android:src="@drawable/ic_message"
        app:fabSize="mini"
        app:backgroundTint="@color/ares_card_bg"
        app:tint="@color/ares_green"
        app:layout_constraintBottom_toTopOf="@id/menu_nav"
        app:layout_constraintEnd_toEndOf="parent" />

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab_camara_entorno"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginBottom="144dp"
        android:layout_marginEnd="16dp"
        android:visibility="invisible"
        android:src="@drawable/ic_camara"
        app:fabSize="mini"
        app:backgroundTint="@color/ares_card_bg"
        app:tint="@color/ares_orange"
        app:layout_constraintBottom_toTopOf="@id/menu_nav"
        app:layout_constraintEnd_toEndOf="parent" />

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab_mic_bitacora"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginBottom="84dp"
        android:layout_marginEnd="16dp"
        android:visibility="invisible"
        android:src="@drawable/ic_mic"
        app:fabSize="mini"
        app:backgroundTint="@color/ares_card_bg"
        app:tint="@color/ares_blue"
        app:layout_constraintBottom_toTopOf="@id/menu_nav"
        app:layout_constraintEnd_toEndOf="parent" />

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab_main"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_marginBottom="16dp"
        android:layout_marginEnd="16dp"
        android:src="@drawable/ic_add"
        app:backgroundTint="@color/ares_blue"
        app:tint="@android:color/white"
        app:layout_constraintBottom_toTopOf="@id/menu_nav"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>